# Copy to `.env` and fill in. NEVER commit your real .env.
# scripts/lib/openai_client.py loads this file via python-dotenv.

OPENAI_API_KEY=sk-...
# Optional — defaults to configs/stage1_generation_plan.yaml model.default (gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.8
OPENAI_MAX_OUTPUT_TOKENS=3000
OPENAI_CONCURRENCY=3
